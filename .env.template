# ============================================
# World Cup 2026 - Backend Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ── Database (PostgreSQL) ──────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=wc2026_user
DB_PASSWORD=wc2026_pass
DB_DATABASE=world_cup_2026

# ── JWT Authentication ─────────────────────
JWT_SECRET=CHANGE_ME_use_a_strong_random_secret
JWT_EXPIRATION=6h

# ── Security ───────────────────────────────
SALT_ROUNDS=10

# ── Server ─────────────────────────────────
PORT=3000
NODE_ENV=development
# NODE_ENV=production

# ── CORS ───────────────────────────────────
# URL del frontend (sin trailing slash)
CORS_ORIGIN=http://localhost:5173

# ── Email (SMTP) ──────────────────────────
# Requerido para envio de contrasenas temporales
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=
MAIL_FROM=noreply@worldcup2026.com
